{
  "colors": {
    "primary": "#E60012",
    "secondary": "#333333",
    "background": "#FFFFFF",
    "surface": "#F8F8F8",
    "text": "#333333",
    "textLight": "#666666",
    "border": "#E0E0E0",
    "white": "#FFFFFF",
    "primaryDark": "#B3000E",
    "primaryLight": "#FF1A2B"
  },
  "spacing": {
    "section": "80px",
    "cardGap": "24px",
    "containerMax": "1200px",
    "containerPadding": "24px"
  },
  "font": {
    "heading": "system-ui, -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans CJK JP', sans-serif",
    "body": "system-ui, -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans CJK JP', sans-serif"
  },
  "borderRadius": {
    "card": "12px",
    "button": "6px",
    "pill": "9999px"
  },
  "shadow": {
    "card": "0 2px 12px rgba(0, 0, 0, 0.08)",
    "cardHover": "0 6px 24px rgba(0, 0, 0, 0.14)",
    "header": "0 2px 8px rgba(0, 0, 0, 0.1)"
  },
  "transition": {
    "base": "0.2s ease",
    "slow": "0.35s ease"
  },
  "zIndex": {
    "header": 100,
    "mobileMenu": 99,
    "overlay": 98
  }
}
